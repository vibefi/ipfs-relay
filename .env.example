# Copy to .env and fill in real values (never commit .env)
#
# Env vars use __ to separate nesting levels (single _ is part of field names):
#   VIBEFI_RELAY__<SECTION>__<FIELD>=value

APP_ENV=development
RUST_LOG=ipfs_relay=debug,tower_http=info

# Server
VIBEFI_RELAY__SERVER__PORT=8080

# Kubo IPFS node
VIBEFI_RELAY__IPFS__KUBO_API_URL=http://127.0.0.1:5001

# Optional API auth for externally exposed Kubo API routes.
# Format: basic:<username>:<password>
KUBO_API_AUTH_SECRET=

# Pinning providers (optional — relay works locally without these)
VIBEFI_RELAY__PINNING__PINATA_JWT=
VIBEFI_RELAY__PINNING__FOUREVERLAND_TOKEN=

# Limits (override defaults from config/default.toml)
# VIBEFI_RELAY__LIMITS__MAX_UPLOAD_BYTES=10485760
# VIBEFI_RELAY__LIMITS__MAX_FILE_COUNT=1500
# VIBEFI_RELAY__LIMITS__STRICT_MANIFEST=false

# Rate limits
# VIBEFI_RELAY__RATE_LIMIT__PER_IP_PER_MINUTE=1
# VIBEFI_RELAY__RATE_LIMIT__PER_IP_PER_HOUR=15
