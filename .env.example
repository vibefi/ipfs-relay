# Copy to .env and fill in real values (never commit .env)
APP_ENV=development
RUST_LOG=ipfs_relay=debug,tower_http=info

# Server
VIBEFI_RELAY_SERVER_PORT=8080

# Database
VIBEFI_RELAY_DATABASE_URL=sqlite://ipfs-relay.db

# Kubo IPFS node
VIBEFI_RELAY_IPFS_KUBO_API_URL=http://127.0.0.1:5001

# Pinning providers (optional — relay works locally without these)
VIBEFI_RELAY_PINNING_PINATA_JWT=
VIBEFI_RELAY_PINNING_FOUREVERLAND_TOKEN=

# API keys (comma-separated; leave empty to accept anonymous uploads only)
VIBEFI_RELAY_AUTH_API_KEYS=

# Limits (override defaults from config/default.toml)
# VIBEFI_RELAY_LIMITS_MAX_UPLOAD_BYTES=10485760
# VIBEFI_RELAY_LIMITS_MAX_FILE_COUNT=1500
# VIBEFI_RELAY_LIMITS_STRICT_MANIFEST=false

# Rate limits
# VIBEFI_RELAY_RATE_LIMIT_PER_IP_PER_HOUR=30
# VIBEFI_RELAY_RATE_LIMIT_PER_KEY_PER_DAY=300
