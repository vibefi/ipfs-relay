# Copy to .env alongside docker-compose.yml and fill in real values.
# This file is committed; .env is gitignored.

# ── Pinning providers ─────────────────────────────────────────────────────────
# Leave blank to run relay-only (no external replication)
VIBEFI_RELAY_PINNING_PINATA_JWT=
VIBEFI_RELAY_PINNING_FOUREVERLAND_TOKEN=

# ── Auth ──────────────────────────────────────────────────────────────────────
# Comma-separated list of valid API keys for trusted callers (higher quotas).
# Leave empty to accept anonymous uploads only.
VIBEFI_RELAY_AUTH_API_KEYS=

# ── Limits (override config/production.toml defaults) ────────────────────────
# VIBEFI_RELAY_LIMITS_MAX_UPLOAD_BYTES=10485760
# VIBEFI_RELAY_LIMITS_MAX_FILE_COUNT=1500
# VIBEFI_RELAY_LIMITS_STRICT_MANIFEST=false

# ── Rate limits ───────────────────────────────────────────────────────────────
# VIBEFI_RELAY_RATE_LIMIT_PER_IP_PER_HOUR=30
# VIBEFI_RELAY_RATE_LIMIT_PER_KEY_PER_DAY=300

# ── Observability ─────────────────────────────────────────────────────────────
RUST_LOG=ipfs_relay=info,tower_http=info
