# Copy to .env alongside docker-compose.yml and fill in real values.
# This file is committed; .env is gitignored.
#
# Env vars use __ to separate nesting levels (single _ is part of field names):
#   VIBEFI_RELAY__<SECTION>__<FIELD>=value

# ── Pinning providers ─────────────────────────────────────────────────────────
# Leave blank to run relay-only (no external replication)
VIBEFI_RELAY__PINNING__PINATA_JWT=
VIBEFI_RELAY__PINNING__FOUREVERLAND_TOKEN=

# ── Auth ──────────────────────────────────────────────────────────────────────
# Comma-separated list of valid API keys for trusted callers (higher quotas).
# Leave empty to accept anonymous uploads only.
VIBEFI_RELAY__AUTH__API_KEYS=

# ── Limits (override config/production.toml defaults) ────────────────────────
# VIBEFI_RELAY__LIMITS__MAX_UPLOAD_BYTES=10485760
# VIBEFI_RELAY__LIMITS__MAX_FILE_COUNT=1500
# VIBEFI_RELAY__LIMITS__STRICT_MANIFEST=false

# ── Rate limits ───────────────────────────────────────────────────────────────
# VIBEFI_RELAY__RATE_LIMIT__PER_IP_PER_HOUR=30
# VIBEFI_RELAY__RATE_LIMIT__PER_KEY_PER_DAY=300

# ── Observability ─────────────────────────────────────────────────────────────
RUST_LOG=ipfs_relay=info,tower_http=info
